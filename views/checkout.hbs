<div class="container my-5" style="max-width: 600px;">
  <div class="card shadow-sm p-4">
    <h2 class="mb-4 text-center">Secure Checkout</h2>
    
    <form id="payment-form">
      <div id="payment-element" class="mb-4">
        <div class="text-center p-3 text-muted">Initializing secure connection to Stripe...</div>
      </div>
      
      <button id="submit-btn" class="btn btn-primary w-100 py-2 fw-bold" disabled>
        <span id="button-text">Authorize & Pay</span>
      </button>
      <div id="payment-message" class="text-danger mt-3 text-center" style="display: none;"></div>
    </form>
  </div>
</div>

<script src="https://js.stripe.com/v3/"></script>

<script>
  // Extract the item selection parameter from the current browser URL query
  const urlParams = new URLSearchParams(window.location.search);
  const itemIndex = urlParams.get('item');

  // 2. Initialize Stripe on the frontend using your publishable key passed dynamically from server variables
  const stripe = Stripe('{{{publishableKey}}}');
  let elements;

  async function initializeCheckout() {
    try {
      // 3. Request a fresh PaymentIntent token from our backend route
      const response = await fetch('/create-payment-intent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ itemIndex }),
      });
      
      const { clientSecret } = await response.json();

      // 4. Instantiation of the Unified Stripe Elements container framework
      elements = stripe.elements({ clientSecret });

      // 5. Create and mount the combined Payment Element form into our HTML anchor layout card
      const paymentElement = elements.create('payment');
      paymentElement.mount('#payment-element');

      // Ready to capture submission interaction events
      document.querySelector('#submit-btn').disabled = false;
    } catch (e) {
      document.querySelector('#payment-message').innerText = "Initialization failed. Check server console configurations.";
      document.querySelector('#payment-message').style.display = "block";
    }
  }

  // 6. Monitor transaction confirmation execution requests
  const form = document.getElementById('payment-form');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = document.querySelector('#submit-btn');
    submitBtn.disabled = true;
    document.querySelector('#button-text').innerText = "Processing Transaction...";

    // Determine the current hosting scheme to build the return landing redirection target
    const currentOrigin = window.location.origin;

    // Trigger the confirmation cycle routing the response to our confirmation file layout
    const { error } = await stripe.confirmPayment({
      elements,
      confirmParams: {
        return_url: `${currentOrigin}/confirmation`,
      },
    });

    // Code execution breaks here if successful redirection succeeds. Errors trigger fall-through traps:
    if (error.type === "card_error" || error.type === "validation_error") {
      const messageContainer = document.querySelector('#payment-message');
      messageContainer.innerText = error.message;
      messageContainer.style.display = "block";
    } else {
      console.error(error);
    }

    submitBtn.disabled = false;
    document.querySelector('#button-text').innerText = "Authorize & Pay";
  });

  initializeCheckout();
</script>